# =============================================================================
# Biller MCP server — variables de entorno (EJEMPLO, sin secretos reales)
# =============================================================================
# Copiá este archivo a `.env` y completá con tus valores.
# NUNCA commitees `.env` con un token real. `.env` está en .gitignore.
#
# IMPORTANTE: empezá SIEMPRE por el ambiente de TEST antes de producción.
# =============================================================================

# --- Requeridas ---------------------------------------------------------------

# Base URL de la API de Biller. Sin path de versión (el server agrega /v2/...).
# Test:        https://test.biller.uy
# Producción:  https://biller.uy
BILLER_API_BASE_URL=https://test.biller.uy

# Bearer Token de la empresa (se obtiene en {ambiente}.biller.uy/api/tokens).
# Cada token está asociado unívocamente a una empresa.
# Este MCP NUNCA loguea ni devuelve el token.
BILLER_API_TOKEN=pegá-tu-token-de-test-aqui

# --- Opcionales ---------------------------------------------------------------

# RUT de la empresa por defecto. Solo metadata local: el token ya está asociado
# a una empresa, por lo que NO se envía a la API.
# BILLER_DEFAULT_EMPRESA_RUT=210475730011

# ID de sucursal por defecto (OPCIONAL). Se usa como valor por defecto del
# parámetro `sucursal` en /v2/comprobantes/obtener cuando la tool no recibe uno
# explícito.
#
# ⚠️ NO es un número genérico tipo "1". Es el ID REAL que Biller le asigna a tu
# sucursal. Obtenelo en {ambiente}.biller.uy → Ajustes → Sucursales.
#
# Podés dejarlo SIN definir: GET /v2/comprobantes/obtener no requiere sucursal
# ("ninguno de los campos es obligatorio"), así que si tu empresa tiene una sola
# sucursal la consulta funciona igual sin este valor.
# BILLER_DEFAULT_SUCURSAL_ID=6

# Timeout de las requests HTTP en milisegundos (default 30000).
# BILLER_TIMEOUT_MS=30000

# Nivel de log a stderr: error | warn | info | debug (default info).
# Los logs NUNCA van a stdout (stdout está reservado para el protocolo MCP).
# LOG_LEVEL=info

# --- Modo operativo -----------------------------------------------------------

# Controla qué tools se registran en el servidor MCP.
# read_only    (default): solo las 6 tools de lectura. Seguro para producción.
# write_enabled          : agrega las 6 tools de escritura (con barreras).
# BILLER_CAPABILITY_MODE=read_only

# --- Escritura ("escritura con barreras") -------------------------------------
# Requiere BILLER_CAPABILITY_MODE=write_enabled para que las tools estén visibles.
# Las tools de escritura SIEMPRE permiten dry-run (preview sin red).
# Para EJECUTAR el POST real, hace falta también BILLER_WRITE_ENABLED=true.

# Master switch de escritura. Con false (default), la ejecución se bloquea.
# BILLER_WRITE_ENABLED=false

# Habilita ejecutar POST contra PRODUCCIÓN (biller.uy). Además del flag, cada
# llamada debe pasar allow_production=true. En test NO hace falta.
# ⚠️ Emitir/anular en producción tiene efectos fiscales REALES ante DGI.
# BILLER_ALLOW_PRODUCTION_WRITES=false

# Ruta opcional de archivo para el audit log de escrituras (además de stderr).
# Nunca registra el token ni el payload completo (solo un hash + metadata).
# BILLER_AUDIT_LOG_PATH=./biller-mcp-audit.log
